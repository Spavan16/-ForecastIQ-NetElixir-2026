# Secrets — never commit
.env
.env.*
!.env.example
!.env.local.example

# Next.js local env (may contain secrets on other projects)
frontend/.env.local

# Python
venv/
__pycache__/
*.pyc
# NOTE: *.pkl is intentionally NOT excluded — pickle/model.pkl must be committed for hackathon submission
# features.pkl (repo root) is a runtime-generated intermediate artifact — run.sh regenerates
# it fresh on every run before it's ever read, so it doesn't need to be committed.
/features.pkl

# SQLite run-history DB (src/database.py) — runtime-generated, grows on every backend run
forecast_iq.db

# CatBoost training logs — auto-regenerated on every train run (catboost_training.json,
# events.out.tfevents, time_left.tsv), pure noise in diffs, not meaningful submission content.
catboost_info/

# Node / Next.js
frontend/node_modules/
frontend/.next/

# OS / editor
.DS_Store
